{
    "name": "patrickwasp/plainbooru",
    "description": "A minimal image/video booru board built with Slim 4, SQLite, and zero client-side JavaScript",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "php-di/php-di": "^7.1.1",
        "picocss/pico": "^2.1",
        "slim/psr7": "^1.8",
        "slim/slim": "^4.15.1",
        "twig/twig": "^3.23"
    },
    "autoload": {
        "psr-4": {
            "Plainbooru\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
