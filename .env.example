# plainbooru environment configuration
# Copy to .env and adjust as needed

# Maximum upload size in MB (default: 50)
MAX_UPLOAD_MB=50

# Optional admin secret token for mutating operations.
# Leave empty for open/anonymous access.
# Set to a strong random value to protect uploads and pool management.
# ADMIN_SECRET=change_me_to_something_secret

# Set to "true" when nginx is configured with X-Accel-Redirect internal locations
# NGINX_ACCEL=true

# SQLite DB path (relative to project root, default: data/plainbooru.sqlite)
# DB_PATH=data/plainbooru.sqlite
